<Window x:Class="LinkRoom.WizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="欢迎使用 LinkRoom" Height="420" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="32,24">
        <TextBlock x:Name="StepTitle" Text="步骤 1/3 — 选择模式" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
        <TextBlock x:Name="StepDesc" Text="选择适合你的联机模式" TextWrapping="Wrap" Foreground="#666" Margin="0,0,0,16"/>
        <CheckBox x:Name="LanModeCheck" Content="LAN 模式（MC 等自动发现，需管理员）" Margin="0,0,0,8"/>
        <CheckBox x:Name="AutoUpdateCheck" Content="启动时自动检查更新" IsChecked="True" Margin="0,0,0,8"/>
        <CheckBox x:Name="PortableCheck" Content="便携模式（数据存 exe 同目录）" IsChecked="True" Margin="0,0,0,24"/>
        <ProgressBar x:Name="WizardProgress" Height="4" Maximum="3" Value="1" Margin="0,0,0,16"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="跳过" Width="80" Margin="0,0,8,0" Click="Skip_Click"/>
            <Button Content="下一步" Width="80" Click="Next_Click"
                    Style="{StaticResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}"/>
        </StackPanel>
    </StackPanel>
</Window>
