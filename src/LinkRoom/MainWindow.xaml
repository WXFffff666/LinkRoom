<Window x:Class="LinkRoom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LinkRoom" Height="520" Width="400"
        MinHeight="400" MinWidth="300"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F7">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="LinkRoom" FontSize="24" FontWeight="Bold"
                   Foreground="#2D2D2D" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="房间号 (Room ID)" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
            <TextBox FontSize="16" Padding="8,6" BorderBrush="#DDD" BorderThickness="1" Background="White"
                 Text="{Binding RoomId, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="密码 (Password)" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
            <PasswordBox FontSize="16" Padding="8,6" BorderBrush="#DDD" BorderThickness="1" Background="White"
                 x:Name="PasswordBox" PasswordChanged="PasswordBox_PasswordChanged"/>
        </StackPanel>

        <Border Grid.Row="3" Background="#EDEDEF" CornerRadius="6" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="StatusIndicator" Width="12" Height="12"
                         Fill="#CCCCCC" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding StatusText}" FontSize="14" Foreground="#333"/>
                    <TextBlock x:Name="DetailText" Text="" FontSize="11" Foreground="#888" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="连接 (Connect)" Height="36" FontSize="14" FontWeight="SemiBold"
                    Background="#007AFF" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Command="{Binding ConnectCommand}"/>
            <Button Grid.Column="2" Content="断开 (Disconnect)" Height="36" FontSize="14" FontWeight="SemiBold"
                    Background="#E0E0E0" Foreground="#333" BorderThickness="0" Cursor="Hand"
                    Command="{Binding DisconnectCommand}"/>
        </Grid>

        <Expander Grid.Row="5" Header="高级设置 (Advanced)"
                  IsExpanded="False" FontSize="13" Foreground="#555" Margin="0,0,0,8">
            <StackPanel Margin="0,8,0,0">
                <CheckBox Content="启用共享节点 (Enable Shared Nodes)" FontSize="12" Margin="0,0,0,6"
                          IsChecked="{Binding IsSharedNodeEnabled}"/>
                <TextBox FontSize="12" Padding="6,4" BorderBrush="#DDD" BorderThickness="1" Background="White"
                         Text="{Binding SharedNodeUrls}"
                         IsEnabled="{Binding IsSharedNodeEnabled}"
                         ToolTip="共享节点地址，如 tcp://example.com:11010"/>
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="日志级别 (Log Level)" FontSize="11" Foreground="#666"/>
                    <ComboBox FontSize="12" Margin="0,4,0,0" SelectedIndex="0"
                              Text="{Binding LogLevel}">
                        <ComboBoxItem Content="Info"/><ComboBoxItem Content="Debug"/><ComboBoxItem Content="Warning"/><ComboBoxItem Content="Error"/>
                    </ComboBox>
                </StackPanel>
                <CheckBox Content="禁用 UPnP (Disable UPnP)" FontSize="12" Margin="0,10,0,0"
                          IsChecked="{Binding IsUpnpDisabled}"/>
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="自定义 STUN 服务器" FontSize="11" Foreground="#666"/>
                    <TextBox FontSize="12" Padding="6,4" BorderBrush="#DDD" BorderThickness="1" Background="White"
                             Text="{Binding CustomStunServers}"/>
                </StackPanel>
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="最大重连次数" FontSize="11" Foreground="#666"/>
                    <TextBox FontSize="12" Padding="6,4" BorderBrush="#DDD" BorderThickness="1" Background="White"
                             Text="{Binding MaxReconnectAttempts}"/>
                </StackPanel>
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="静态虚拟 IP (留空使用 DHCP)" FontSize="11" Foreground="#666"/>
                    <TextBox FontSize="12" Padding="6,4" BorderBrush="#DDD" BorderThickness="1" Background="White"
                             Text="{Binding StaticVirtualIp}"/>
                </StackPanel>
            </StackPanel>
        </Expander>

        <TextBox Grid.Row="6" Height="60" IsReadOnly="True"
                 FontFamily="Consolas" FontSize="10" Background="#1E1E1E" Foreground="#CCC"
                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                 Visibility="Collapsed" Margin="0,8,0,0"
                 x:Name="LogViewer"/>
    </Grid>
</Window>