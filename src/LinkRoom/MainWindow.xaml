<Window x:Class="LinkRoom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        ui:ThemeManager.IsThemeAware="True"
        ui:WindowHelper.SystemBackdropType="Mica"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Height="40" ui:TitleBar.IsIconVisible="True"
        Title="LinkRoom" Height="460" Width="400"
        MinHeight="380" MinWidth="340"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="12,6" LastChildFill="False">
            <Button Content="⚙ 设置" FontSize="11" Foreground="#8E8E93" Background="Transparent"
                    BorderThickness="0" Click="OpenSettings_Click" Cursor="Hand" Margin="0,0,4,0"/>
            <Button Content="📋 日志" FontSize="11" Foreground="#8E8E93" Background="Transparent"
                    BorderThickness="0" Click="OpenLog_Click" Cursor="Hand" DockPanel.Dock="Right"/>
        </DockPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="40,0">
            <TextBlock Text="LinkRoom" FontSize="24" FontWeight="Bold" Foreground="#1D1D1F" HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="P2P 联机 · 创建或加入房间" FontSize="11" Foreground="#8E8E93" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="房间号" FontSize="12" Foreground="#8E8E93" Margin="0,0,0,6"/>
            <TextBox FontSize="16" Padding="12,10" Text="{Binding RoomId, UpdateSourceTrigger=PropertyChanged}"
                     BorderBrush="#E5E5EA" BorderThickness="1" ToolTip="创建时留空自动生成, 加入时输入好友房间号"/>

            <TextBlock Text="密码（可选）" FontSize="12" Foreground="#8E8E93" Margin="0,14,0,6"/>
            <PasswordBox FontSize="16" Padding="12,10" x:Name="PasswordBox" PasswordChanged="PasswordBox_PasswordChanged"
                         BorderBrush="#E5E5EA" BorderThickness="1"/>

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="创建房间" Height="44" FontSize="14" FontWeight="SemiBold"
                        Command="{Binding CreateRoomCommand}"
                        Style="{StaticResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}"/>
                <Button Grid.Column="2" Content="加入房间" Height="44" FontSize="14" FontWeight="SemiBold"
                        Command="{Binding ConnectCommand}"
                        Style="{StaticResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}"/>
            </Grid>

            <Button Content="断开" Height="32" FontSize="11" Margin="0,8,0,0" Command="{Binding DisconnectCommand}"
                    Foreground="#FF3B30" Background="Transparent" BorderThickness="0" Cursor="Hand"/>

            <Border Background="#E8F5E9" CornerRadius="8" Padding="12" Margin="0,12,0,0"
                    x:Name="CreatedRoomPanel" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="✅ 房间已创建！" FontSize="13" FontWeight="SemiBold" Foreground="#2E7D32"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="房间号: " FontSize="16" FontWeight="Bold" Foreground="#1B5E20" VerticalAlignment="Center"/>
                        <TextBox x:Name="CreatedRoomId" FontSize="16" FontWeight="Bold" Foreground="#1B5E20"
                                 IsReadOnly="True" BorderThickness="0" Background="Transparent" Width="150"
                                 MouseDoubleClick="CreatedRoomId_DoubleClick" ToolTip="双击复制" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#8E8E93" HorizontalAlignment="Center"
                       Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center"/>

            <!-- Peer list (visible when connected) -->
            <ItemsControl ItemsSource="{Binding Peers}" Margin="0,8,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#F5F5F7" CornerRadius="6" Padding="8,6" Margin="0,2">
                            <TextBlock FontSize="11" Foreground="#6E6E73" TextWrapping="Wrap"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <Border Grid.Row="2" Padding="6" Background="Transparent">
            <DockPanel>
                <TextBlock Text="v0.6.0" FontSize="10" Foreground="#C7C7CC" DockPanel.Dock="Right"/>
                <TextBlock Text="{Binding StatusDetail}" FontSize="10" Foreground="#C7C7CC"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>