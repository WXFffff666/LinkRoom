<Window x:Class="LinkRoom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        ui:ThemeManager.IsThemeAware="True"
        ui:WindowHelper.SystemBackdropType="Mica"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Height="40"
        ui:TitleBar.IsIconVisible="True"
        Title="LinkRoom" Height="560" Width="420"
        MinHeight="420" MinWidth="340"
        WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,8,24,24">
            <!-- Title -->
            <TextBlock Text="LinkRoom" FontSize="28" FontWeight="Bold"
                       Foreground="#1D1D1F" HorizontalAlignment="Center" Margin="0,0,0,16"/>

            <!-- Room ID -->
            <TextBlock Text="房间号 (Room ID)" FontSize="14" Foreground="#6E6E73" Margin="0,0,0,4"/>
            <TextBox FontSize="16" Padding="10,8"
                 Text="{Binding RoomId, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Password -->
            <TextBlock Text="密码 (Password)" FontSize="14" Foreground="#6E6E73" Margin="0,16,0,4"/>
            <PasswordBox FontSize="16" Padding="10,8" x:Name="PasswordBox"
                         PasswordChanged="PasswordBox_PasswordChanged"/>

            <!-- Status Card -->
            <Border Background="White" CornerRadius="8" Padding="16" Margin="0,16,0,0"
                    BorderBrush="#E5E5EA" BorderThickness="1">
                <StackPanel>
                    <DockPanel>
                        <Ellipse x:Name="StatusIndicator" Width="10" Height="10" Fill="#CCCCCC"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding StatusText}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#1D1D1F"/>
                    </DockPanel>
                    <TextBlock x:Name="DetailPanel" Text="" FontSize="12" Foreground="#6E6E73"
                               TextWrapping="Wrap" Margin="18,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Connect/Disconnect -->
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="连接" Height="40" FontSize="15" FontWeight="SemiBold"
                        Command="{Binding ConnectCommand}"
                        Style="{StaticResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}"/>
                <Button Grid.Column="2" Content="断开" Height="40" FontSize="15" FontWeight="SemiBold"
                        Command="{Binding DisconnectCommand}"
                        Style="{StaticResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}"/>
            </Grid>

            <!-- Advanced Section -->
            <Expander Header="高级设置 (Advanced)" IsExpanded="False" Margin="0,12,0,0"
                      Foreground="#6E6E73">
                <StackPanel Margin="0,8,0,0">
                    <CheckBox Content="启用共享节点" IsChecked="{Binding IsSharedNodeEnabled}"
                              Foreground="#1D1D1F" Margin="0,0,0,8"/>
                    <TextBox Padding="6,4" Text="{Binding SharedNodeUrls}"
                             IsEnabled="{Binding IsSharedNodeEnabled}" Margin="0,0,0,8"/>

                    <TextBlock Text="日志级别" Foreground="#6E6E73" Margin="0,4,0,4"/>
                    <ComboBox Text="{Binding LogLevel}" Margin="0,0,0,8">
                        <ComboBoxItem Content="Info"/><ComboBoxItem Content="Debug"/>
                        <ComboBoxItem Content="Warning"/><ComboBoxItem Content="Error"/>
                    </ComboBox>

                    <CheckBox Content="禁用 UPnP" IsChecked="{Binding IsUpnpDisabled}"
                              Foreground="#1D1D1F" Margin="0,0,0,8"/>

                    <TextBlock Text="自定义 STUN 服务器" Foreground="#6E6E73" Margin="0,4,0,4"/>
                    <TextBox Padding="6,4" Text="{Binding CustomStunServers}" Margin="0,0,0,8"/>

                    <TextBlock Text="最大重连次数" Foreground="#6E6E73" Margin="0,4,0,4"/>
                    <TextBox Padding="6,4" Text="{Binding MaxReconnectAttempts}" Margin="0,0,0,8"/>

                    <TextBlock Text="静态虚拟 IP (留空使用 DHCP)" Foreground="#6E6E73" Margin="0,4,0,4"/>
                    <TextBox Padding="6,4" Text="{Binding StaticVirtualIp}"/>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</Window>