<Window x:Class="LinkRoom.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="日志" Height="500" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="📋 运行日志" FontSize="14" FontWeight="Bold" Foreground="#1D1D1F" DockPanel.Dock="Left"/>
            <Button Content="清空" FontSize="11" Click="Clear_Click" DockPanel.Dock="Right"
                    Background="Transparent" BorderThickness="0" Foreground="#FF3B30" Cursor="Hand"/>
            <Button Content="复制" FontSize="11" Click="Copy_Click" DockPanel.Dock="Right" Margin="0,0,8,0"
                    Background="Transparent" BorderThickness="0" Foreground="#007AFF" Cursor="Hand"/>
        </DockPanel>

        <TextBox x:Name="LogContent" Grid.Row="1" IsReadOnly="True"
                 FontFamily="Consolas" FontSize="11" Background="#1E1E1E" Foreground="#D4D4D4"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" BorderThickness="0"/>

        <Button Grid.Row="2" Content="关闭" Height="32" FontSize="12" Margin="0,8,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>